{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "declaration": true,
    "outDir": "dist",
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*",
    "tests/chunker.test.ts"
  ]
}