{
  "name": "@sage-pond/sdk",
  "version": "1.0.0-alpha.1",
  "description": "SDK for SAGE POND API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "sagepond": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --watch --dts",
    "test": "vitest run"
  },
  "keywords": [
    "sagepond",
    "sdk",
    "api"
  ],
  "author": "Caleb Matovu <matovucaleb2@sagepond.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "axios": "^1.6.0",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}